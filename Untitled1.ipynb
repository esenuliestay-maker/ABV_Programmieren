   "source": [
    "zahl = input(\"Geben Sie eine Zahl ein: \")\n",
    "\n",
    "if zahl.count('.') == 1 and zahl.replace('.', '').isdigit():\n",
    "    print(\"Es ist eine Float-Zahl.\")\n",
    "    \n",
    "    zahl_float = float(zahl)\n",
    "    print(\"Als float:\", zahl_float)\n",
    "else:\n",
    "    print(\"Es ist keine Float-Zahl.\")"
   ]
